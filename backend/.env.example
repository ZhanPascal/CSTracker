# Copier ce fichier en .env et remplir les valeurs
# Utilisé uniquement pour le développement local (npm run dev)
# En Docker, les variables sont injectées par docker-compose.yml

PORT=5000
DATABASE_URL="postgresql://user:password@localhost:5432/cstracker_db"
RIOT_API_KEY=RGAPI-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
LEAGUEPEDIA_USERNAME=WikiUsername@BotName
LEAGUEPEDIA_PASSWORD=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
